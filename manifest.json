{
  "manifest_version": 3,
  "name": "YouTube description capture",
  "version": "1.0",
  "description": "Captures YouTube descriptions in real-time",
  "author" : "BEKKALI AMINE",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content_script.js"]
    }
  ],

  "side_panel": {
    "default_path": "sidebar.html"
  },

  "action": {
    "default_title": "Caption Capture",
    "default_icon": "icon.png"
    
  },
  "icons": {
  "128": "icon.png"
}
}